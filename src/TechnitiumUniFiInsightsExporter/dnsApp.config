{
  "enabled": false,
  "destination": {
    "address": "192.0.2.10",
    "port": 1516,
    "protocol": "UDP"
  },
  "nodePolicy": {
    "mode": "allowList",
    "serverDomains": [
      "resolver1.example.net",
      "resolver2.example.net"
    ]
  },
  "syslog": {
    "priority": 134,
    "hostnameMode": "serverDomain",
    "appName": "dnsmasq",
    "processId": "1",
    "timeZone": "Europe/Berlin"
  },
  "queue": {
    "capacity": 50000,
    "fullMode": "dropNewest",
    "shutdownDrainTimeoutSeconds": 5
  },
  "filters": {
    "excludeQueryTypes": ["SOA", "IXFR", "AXFR"],
    "excludeDomains": [],
    "excludeSuffixes": [],
    "excludeRegex": [],
    "stripTrailingDot": true,
    "clusterNoise": {
      "clientAddresses": [],
      "domainContains": [],
      "excludeReverseLookups": false
    }
  },
  "observability": {
    "logStartupSummary": true,
    "logPeriodicCounters": true,
    "counterIntervalSeconds": 300,
    "includeQueryDataInLogs": false
  }
}
